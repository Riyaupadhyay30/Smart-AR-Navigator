<div style="
    position:relative;
    background: linear-gradient(135deg, #0b132b, #1c2541);
    min-height:100vh;
    color:white;
    font-family:Poppins;
    display:flex;
    justify-content:center;
    align-items:center;
    overflow:hidden;
">

    <!-- PARTICLES -->
    <div id="particles"></div>

    <div style="text-align:center; position:relative; z-index:1;">

        <h2 style="margin-bottom:5px;">Select Location</h2>

        <p style="opacity:0.7; margin-bottom:35px;">
            Destination: <b>@ViewBag.Destination</b>
        </p>

        <!-- 🔥 DYNAMIC CARDS -->
        <div id="locations" style="
            display:flex;
            gap:25px;
            flex-wrap:wrap;
            justify-content:center;
        "></div>

        <!-- BUTTON -->
        <button onclick="goNext()" style="
            margin-top:40px;
            padding:14px 35px;
            border-radius:30px;
            border:none;
            background: linear-gradient(45deg, #3b82f6, #06b6d4);
            color:white;
            font-weight:600;
            cursor:pointer;
            box-shadow:0 0 20px rgba(59,130,246,0.6);
            transition:0.3s;
        "
        onmouseover="this.style.transform='scale(1.08)'; this.style.boxShadow='0 0 40px rgba(59,130,246,1)'"
        onmouseout="this.style.transform='scale(1)'; this.style.boxShadow='0 0 20px rgba(59,130,246,0.6)'">
            Continue →
        </button>

    </div>

</div>

<script>
let selected = "";
let destination = "@ViewBag.Destination";

// 🔥 IMPORTANT: mode aa raha hai NavigationType se
let mode = "@ViewBag.Mode"; // "Map" or "AR"

// 🔥 LOCATION DATA
let data = {
    "Explore Campus": ["Admin Block","Lab Block","Library","Canteen","Auditorium","Computer Center","Classroom Block","Cafeteria"],
    "Meet Faculty": ["Admin Block"],
    "Admission Inquiry": ["Admin Block"],
    "Find Classroom": ["Classroom Block","Lab Block"],
    "Facilities": ["Library","Canteen","Cafeteria","Computer Center"]
};

// 🔥 CREATE CARDS
const container = document.getElementById("locations");

(data[destination] || data["Explore Campus"]).forEach(loc => {
    let div = document.createElement("div");

    div.className = "card";
    div.innerHTML = `<p>${loc}</p>`;

    div.onclick = function(){
        selected = loc;

        document.querySelectorAll('.card').forEach(c=>{
            c.style.background="rgba(255,255,255,0.05)";
        });

        div.style.background="rgba(59,130,246,0.3)";
    };

    container.appendChild(div);
});

// 🔥 FINAL NAVIGATION LOGIC
function goNext(){
    if(selected==""){
        alert("Select a location");
        return;
    }

    // 🔥 KEY CHANGE
    if(mode === "AR"){
        window.location.href = "/Navigation/AR?location="
            + encodeURIComponent(selected)
            + "&destination=" + encodeURIComponent(destination);
    }
    else{
        window.location.href = "/Navigation/Map?location="
            + encodeURIComponent(selected)
            + "&destination=" + encodeURIComponent(destination);
    }
}

// PARTICLES
const p = document.getElementById("particles");
for (let i = 0; i < 40; i++) {
    let dot = document.createElement("div");
    dot.style.position = "absolute";
    dot.style.width = "4px";
    dot.style.height = "4px";
    dot.style.background = "white";
    dot.style.borderRadius = "50%";
    dot.style.opacity = Math.random();
    dot.style.top = Math.random() * 100 + "%";
    dot.style.left = Math.random() * 100 + "%";
    dot.style.animation = `float ${5 + Math.random()*10}s linear infinite`;
    p.appendChild(dot);
}
</script>

<style>
#particles {
    position:absolute;
    width:100%;
    height:100%;
    top:0;
    left:0;
    z-index:0;
}

@@keyframes float {
    from { transform: translateY(0); }
    to { transform: translateY(-100vh); }
}

.card {
    width:170px;
    padding:20px;
    border-radius:15px;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    cursor:pointer;
    transition:0.3s;
    text-align:center;
}

.card:hover {
    transform: scale(1.1);
}
</style>