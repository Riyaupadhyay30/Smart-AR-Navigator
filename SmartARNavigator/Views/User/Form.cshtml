<div style="
    position:relative;
    background: linear-gradient(135deg, #0b132b, #1c2541);
    min-height:100vh;
    color:white;
    font-family:'Poppins', sans-serif;
    display:flex;
    justify-content:center;
    align-items:center;
    overflow:hidden;
">

    <!-- PARTICLES -->
    <div id="particles"></div>

    <div style="
        background: rgba(255,255,255,0.05);
        padding:40px;
        border-radius:20px;
        width:360px;
        text-align:center;
        box-shadow:0 20px 40px rgba(0,0,0,0.5);
        position:relative;
        z-index:1;
    ">

        <h2>User Details</h2>

        <p style="opacity:0.7; margin-bottom:20px;">
            Destination: <b>@ViewBag.Destination</b>
        </p>

        @if (ViewBag.Error != null)
        {
            <p style="color:#f87171;">@ViewBag.Error</p>
        }

        <form method="post" action="/User/Submit">

            <input type="hidden" name="Destination" value="@ViewBag.Destination" />

            <input type="text" name="Name" placeholder="Enter your name" required
                   style="width:100%; padding:12px; margin-bottom:12px; border:none; border-radius:10px; box-sizing:border-box; background:white; color:black;" />

            <input type="email" name="Email" placeholder="Email address" required
                   style="width:100%; padding:12px; margin-bottom:12px; border:none; border-radius:10px; box-sizing:border-box; background:white; color:black;" />

            <input type="text" name="Phone" placeholder="Phone number" required
                   style="width:100%; padding:12px; margin-bottom:12px; border:none; border-radius:10px; box-sizing:border-box; background:white; color:black;" />

            <select name="VisitType" required
                    style="width:100%; padding:12px; margin-bottom:20px; border:none; border-radius:10px; box-sizing:border-box; background:white; color:black;">
                <option value="">Select Visit Type</option>
                <option value="Student">Student</option>
                <option value="Parent">Parent</option>
                <option value="Guest">Guest</option>
            </select>

            <button type="submit" style="
                width:100%;
                padding:14px;
                border:none;
                border-radius:25px;
                background: linear-gradient(45deg, #3b82f6, #06b6d4);
                color:white;
                font-weight:600;
                cursor:pointer;
                transition:0.3s;
                box-shadow:0 0 20px rgba(59,130,246,0.6);
            "
            onmouseover="this.style.transform='scale(1.05)'; this.style.boxShadow='0 0 40px rgba(59,130,246,1)'"
            onmouseout="this.style.transform='scale(1)'; this.style.boxShadow='0 0 20px rgba(59,130,246,0.6)'">
                Submit →
            </button>

        </form>

    </div>

</div>

<!-- PARTICLES SCRIPT -->
<script>
const container = document.getElementById("particles");

for (let i = 0; i < 40; i++) {
    let dot = document.createElement("div");

    dot.style.position = "absolute";
    dot.style.width = "4px";
    dot.style.height = "4px";
    dot.style.background = "white";
    dot.style.borderRadius = "50%";
    dot.style.opacity = Math.random();

    dot.style.top = Math.random() * 100 + "%";
    dot.style.left = Math.random() * 100 + "%";

    dot.style.animation = `float ${5 + Math.random()*10}s linear infinite`;

    container.appendChild(dot);
}
</script>

<style>
#particles {
    position:absolute;
    width:100%;
    height:100%;
    top:0;
    left:0;
    z-index:0;
    overflow:hidden;
}

@@keyframes float {
    from { transform: translateY(0); }
    to { transform: translateY(-100vh); }
}
</style>